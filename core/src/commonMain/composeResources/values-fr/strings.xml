    <!-- Guides intégrés : ce que chaque écran sait faire. -->
    <string name="guide_help">Que trouve-t-on sur cet écran ?</string>
    <string name="guide_got_it">J'ai compris</string>
    <string name="guide_tips_title">Aide et astuces</string>
    <string name="guide_tips_show">Afficher les astuces sur les nouveaux écrans</string>
    <string name="guide_tips_show_desc">Ouvre un guide court lors de votre première visite d'un écran.</string>
    <string name="guide_tips_reset">Réinitialiser les astuces</string>
    <string name="guide_tips_reset_done">Les astuces réapparaîtront sur chaque écran.</string>

    <string name="guide_dashboard_title">Tableau de bord</string>
    <string name="guide_dashboard_intro">Vos finances en un coup d'œil, pour le compte affiché.</string>
    <string name="guide_dashboard_1_title">Le solde suit votre compte</string>
    <string name="guide_dashboard_1_body">Le total correspond au solde d'ouverture plus toutes les transactions, recalculé en direct. Changez de compte en haut pour l'ajuster.</string>
    <string name="guide_dashboard_2_title">Balayez pour supprimer, avec annulation</string>
    <string name="guide_dashboard_2_body">Balayez une transaction récente pour la supprimer. Une annulation apparaît aussitôt — rien ne se perd par accident.</string>
    <string name="guide_dashboard_3_title">Analyses IA</string>
    <string name="guide_dashboard_3_body">De courtes observations sur vos dépenses. Masquez celles qui ne vous servent pas ; elles se renouvellent avec le temps.</string>

    <string name="guide_transactions_title">Transactions</string>
    <string name="guide_transactions_intro">Toutes vos entrées, groupées par jour, avec recherche et filtres.</string>
    <string name="guide_transactions_1_title">Rechercher et filtrer</string>
    <string name="guide_transactions_1_body">Cherchez dans les descriptions et les notes, puis affinez par catégorie ou par revenus et dépenses.</string>
    <string name="guide_transactions_2_title">Balayez pour supprimer, avec annulation</string>
    <string name="guide_transactions_2_body">Balayez une ligne pour la supprimer. L'annulation la remet sur son compte d'origine.</string>
    <string name="guide_transactions_3_title">Les entrées vont au compte actif</string>
    <string name="guide_transactions_3_body">Une nouvelle entrée est enregistrée sur le compte affiché. Vous consultez tous les comptes ? Choisissez-en un dans l'éditeur.</string>
    <string name="guide_transactions_4_title">Entrées récurrentes</string>
    <string name="guide_transactions_4_body">Utilisez le bouton de répétition en haut pour planifier loyer, salaire ou abonnements. Ils sont ajoutés automatiquement à échéance.</string>

    <string name="guide_budgets_title">Budgets</string>
    <string name="guide_budgets_intro">Des limites mensuelles par catégorie, et votre position par rapport à chacune.</string>
    <string name="guide_budgets_1_title">Les dépenses sont comptées pour vous</string>
    <string name="guide_budgets_1_body">Le montant dépensé est calculé à partir de vos transactions réelles sur la période — définissez la limite, rien d'autre à tenir à jour.</string>
    <string name="guide_budgets_2_title">Les couleurs sont un avertissement</string>
    <string name="guide_budgets_2_body">Vert : dans les clous. Orange : proche de la limite. Rouge : dépassée. Chaque jauge le dit aussi en toutes lettres.</string>
    <string name="guide_budgets_3_title">Les budgets couvrent tous les comptes</string>
    <string name="guide_budgets_3_body">Un budget s'applique à tous vos comptes : il ne change pas quand vous changez le compte affiché.</string>

    <string name="guide_goals_title">Objectifs</string>
    <string name="guide_goals_intro">Ce pour quoi vous épargnez, et si vous y arriverez à temps.</string>
    <string name="guide_goals_1_title">Ajouter et retirer des fonds</string>
    <string name="guide_goals_1_body">Mettez de l'argent de côté au fil du temps, et reprenez-le si vos plans changent. L'objectif conserve son historique.</string>
    <string name="guide_goals_2_title">Date de fin projetée</string>
    <string name="guide_goals_2_body">Dès que vous avez épargné, nous projetons une date d'arrivée selon votre rythme, et signalons si elle dépasse votre échéance.</string>
    <string name="guide_goals_3_title">Modifier sans risque</string>
    <string name="guide_goals_3_body">Changer le nom ou le montant cible conserve tout ce que vous avez déjà épargné.</string>

    <string name="guide_accounts_title">Comptes</string>
    <string name="guide_accounts_intro">Tous vos comptes — espèces, cartes, épargne — et leur total.</string>
    <string name="guide_accounts_1_title">Le sélecteur ajuste toute l'app</string>
    <string name="guide_accounts_1_body">Choisir un compte en haut restreint le tableau de bord, les transactions et les rapports à ce compte. Choisissez « Tous les comptes » pour tout voir ensemble.</string>
    <string name="guide_accounts_2_title">Valeur nette</string>
    <string name="guide_accounts_2_body">Vos comptes additionnés, les cartes de crédit comptant comme des dettes. Les soldes se mettent à jour depuis vos transactions.</string>
    <string name="guide_accounts_3_title">Un virement n'est pas une dépense</string>
    <string name="guide_accounts_3_body">Déplacer de l'argent entre vos comptes est enregistré des deux côtés, mais exclu des revenus et des dépenses — ce n'est ni l'un ni l'autre.</string>
    <string name="guide_accounts_4_title">Archiver, rapprocher, supprimer</string>
    <string name="guide_accounts_4_body">Archiver masque un compte en gardant son historique. Le rapprochement corrige un solde pour coller à la réalité. Supprimer efface le compte et ses transactions définitivement.</string>

    <string name="guide_reports_title">Rapports</string>
    <string name="guide_reports_intro">Où est passé votre argent, et comment cela se compare à avant.</string>
    <string name="guide_reports_1_title">Comparé à la période précédente</string>
    <string name="guide_reports_1_body">Chaque total est comparé à la période juste avant, de même durée, pour voir la tendance.</string>
    <string name="guide_reports_2_title">Les virements sont exclus</string>
    <string name="guide_reports_2_body">L'argent déplacé entre vos comptes est écarté : il ne peut pas gonfler à la fois vos revenus et vos dépenses.</string>
    <string name="guide_reports_3_title">Exporter en CSV</string>
    <string name="guide_reports_3_body">Exportez la période vers un tableur. Contrairement aux graphiques, l'export inclut les virements, signalés dans une colonne — c'est un relevé, pas une analyse.</string>

