    <string name="guide_dashboard_title">Dashboard</string>
    <string name="guide_dashboard_intro">Your money at a glance for the account you're viewing.</string>
    <string name="guide_dashboard_1_title">Balance follows your account</string>
    <string name="guide_dashboard_1_body">The total is the opening balance plus every transaction, recalculated live. Switch accounts at the top to re-scope it.</string>
    <string name="guide_dashboard_2_title">Swipe to delete, with undo</string>
    <string name="guide_dashboard_2_body">Swipe a recent transaction to remove it. An Undo appears straight after — nothing is lost by accident.</string>
    <string name="guide_dashboard_3_title">AI insights</string>
    <string name="guide_dashboard_3_body">Short observations about your spending. Dismiss any you don't want; they refresh over time.</string>

    <string name="guide_transactions_title">Transactions</string>
    <string name="guide_transactions_intro">Every entry, grouped by day, searchable and filterable.</string>
    <string name="guide_transactions_1_title">Search and filter</string>
    <string name="guide_transactions_1_body">Search descriptions and notes, then narrow by category or by income vs expense.</string>
    <string name="guide_transactions_2_title">Swipe to delete, with undo</string>
    <string name="guide_transactions_2_body">Swipe any row to delete it. Undo restores it to its original account.</string>
    <string name="guide_transactions_3_title">Entries land on the active account</string>
    <string name="guide_transactions_3_body">A new entry goes to the account you're viewing. Viewing all accounts? Pick one in the editor.</string>
    <string name="guide_transactions_4_title">Repeating entries</string>
    <string name="guide_transactions_4_body">Use the repeat button in the header to schedule rent, salary, or subscriptions. They're added for you as they fall due.</string>

    <string name="guide_budgets_title">Budgets</string>
    <string name="guide_budgets_intro">Monthly limits per category, and how close you are to each.</string>
    <string name="guide_budgets_1_title">Spending is counted for you</string>
    <string name="guide_budgets_1_body">Spent is added up from your actual transactions in the period — set the limit and nothing else to maintain.</string>
    <string name="guide_budgets_2_title">Colours are a warning</string>
    <string name="guide_budgets_2_body">Green is on track, amber means you're close to the limit, red means you've passed it. Each gauge also says so in words.</string>
    <string name="guide_budgets_3_title">Budgets cover every account</string>
    <string name="guide_budgets_3_body">A budget spans all your accounts, so it doesn't change when you switch the account you're viewing.</string>

    <string name="guide_goals_title">Goals</string>
    <string name="guide_goals_intro">What you're saving towards, and whether you'll get there in time.</string>
    <string name="guide_goals_1_title">Add and withdraw funds</string>
    <string name="guide_goals_1_body">Put money aside as you go, and take it back out if plans change. The goal keeps its history either way.</string>
    <string name="guide_goals_2_title">Projected finish date</string>
    <string name="guide_goals_2_body">Once you've saved something, we project a completion date from your rate so far, and flag when it's later than your target.</string>
    <string name="guide_goals_3_title">Editing is safe</string>
    <string name="guide_goals_3_body">Changing a goal's name or target keeps everything you've already saved.</string>

    <string name="guide_accounts_title">Accounts</string>
    <string name="guide_accounts_intro">Every account you hold — cash, cards, savings — and what they add up to.</string>
    <string name="guide_accounts_1_title">The switcher re-scopes the app</string>
    <string name="guide_accounts_1_body">Picking an account at the top narrows your dashboard, transactions, and reports to it. Pick "All accounts" to see everything together.</string>
    <string name="guide_accounts_2_title">Net worth</string>
    <string name="guide_accounts_2_body">Your accounts added together, with credit cards counted as debt. Balances update themselves from your transactions.</string>
    <string name="guide_accounts_3_title">Transfers aren't spending</string>
    <string name="guide_accounts_3_body">Moving money between your own accounts is recorded on both, but left out of income and expenses — it isn't either.</string>
    <string name="guide_accounts_4_title">Archive, reconcile, delete</string>
    <string name="guide_accounts_4_body">Archive hides an account but keeps its history. Reconcile corrects a balance to match reality. Delete removes the account and its transactions for good.</string>

    <string name="guide_reports_title">Reports</string>
    <string name="guide_reports_intro">Where your money went, and how it compares to before.</string>
    <string name="guide_reports_1_title">Compared to last period</string>
    <string name="guide_reports_1_body">Every total is measured against the period just before it, of the same length, so you can see the direction of travel.</string>
    <string name="guide_reports_2_title">Transfers are excluded</string>
    <string name="guide_reports_2_body">Money moved between your own accounts is left out, so it can't inflate both your income and your spending.</string>
    <string name="guide_reports_3_title">Export to CSV</string>
    <string name="guide_reports_3_body">Export the period for a spreadsheet. Unlike the charts it includes transfers, marked in their own column — it's a record, not an analysis.</string>

