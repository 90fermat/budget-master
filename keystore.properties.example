# Copy to keystore.properties (gitignored) to sign release builds locally.
#
# Without this file — or the matching ANDROID_KEYSTORE_FILE / ANDROID_KEYSTORE_PASSWORD /
# ANDROID_KEY_ALIAS / ANDROID_KEY_PASSWORD environment variables used by CI — `assembleRelease`
# still builds, it just produces an unsigned APK. That keeps the release build verifiable by
# anyone without handing them the signing key.
#
# storeFile is resolved relative to the repository root.

storeFile=release.jks
storePassword=
keyAlias=budgetmaster
keyPassword=
