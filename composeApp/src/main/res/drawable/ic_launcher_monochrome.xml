<?xml version="1.0" encoding="utf-8"?>
<!--
    Themed-icon layer for Android 13+, where the launcher tints a single-colour silhouette to match
    the wallpaper. Same geometry, no colour of its own: the system supplies it, and anything hard
    coded here would fight the user's theme rather than follow it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108"
    android:tint="?attr/colorControlNormal">

    <path
        android:pathData="M36,70 A22,22 0 1 1 72,70"
        android:strokeColor="#FFFFFFFF"
        android:strokeAlpha="0.35"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
    <path
        android:pathData="M36,70 A22,22 0 0 1 66,49"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
    <path
        android:pathData="M54,59m-5,0a5,5 0 1,0 10,0a5,5 0 1,0 -10,0"
        android:fillColor="#FFFFFFFF" />
</vector>
