<?xml version="1.0" encoding="utf-8"?>
<!--
    The gauge for a light window.

    Not the launcher artwork recoloured: gold that reads as light against charcoal turns washed out
    on white. The arc drops to a deeper amber and the track becomes dark-on-light, so the mark keeps
    the same contrast rather than the same hex values.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M36,70 A22,22 0 1 1 72,70"
        android:strokeColor="#FF1C1917"
        android:strokeAlpha="0.16"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
    <path
        android:pathData="M36,70 A22,22 0 0 1 66,49"
        android:strokeColor="#FFD97706"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
    <path
        android:pathData="M54,59m-5,0a5,5 0 1,0 10,0a5,5 0 1,0 -10,0"
        android:fillColor="#FF1C1917" />
</vector>
