<?xml version="1.0" encoding="utf-8"?>
<!-- Toasts for a shared-in message. Android resources rather than compose-resources because they
     are shown from the Activity, before any Compose content exists. -->
<resources>
    <string name="share_import_ok">Transaction imported</string>
    <string name="share_import_skipped">Already recorded, or not a transaction message</string>
    <!-- Distinct from "skipped": the message was understood, and is waiting on the user. -->
    <string name="share_import_review">Sent to review in Transactions - it may be one you already entered</string>
    <string name="share_import_disabled">Turn on mobile-money import in Settings first</string>
</resources>
