<?xml version="1.0" encoding="utf-8"?>
<!--
  Legacy auto-backup rules, for Android 11 and below (API 30-).

  `data_extraction_rules.xml` covers API 31+; this file is what those older versions read, and
  omitting it would leave them with the old permissive behaviour. Same intent: the finance
  database and the settings store never leave the device through Google's backup.
-->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="datastore" />
</full-backup-content>
