<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">


    <!-- Mobile-money import. Restricted permissions: a Play release needs a Permissions
         Declaration and may be refused. Both are gated behind an explicit in-app opt-in, and the
         app degrades to manual entry when they are absent.
         RECEIVE_SMS captures new messages; READ_SMS backfills history already on the device. -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- Android 13+ gates notifications at runtime. Requested when the user enables SMS import,
         which is when captures need to announce themselves; denial degrades to the in-app inbox. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".BudgetMasterApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="Budget Master"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.NoActionBar">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.NoActionBar">
            <!-- Share a mobile-money message straight in. The fallback capture path: needed if
                 the SMS permission is refused, for messages the receiver missed, and on any
                 platform without SMS access. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Only Orange/MTN shortcodes are ever inspected; everything else is dropped before the
             body is touched. Not exported beyond the system SMS broadcast. -->
        <receiver
            android:name=".MoneyMessageReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
